# ==============================
# Huanfa International Logistics
# Environment Variables Example
# ==============================

# Email Configuration (Resend - https://resend.com)
# Sign up for a free account and get your API key
RESEND_API_KEY=re_xxxxxxxxxxxx
# Email address where inquiries will be sent
NOTIFY_EMAIL=your-email@gmail.com

# Next.js public URL (used for canonical URLs)
NEXT_PUBLIC_SITE_URL=https://huanfa-logistics.com
